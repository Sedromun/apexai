<Window x:Class="ApexAI.App.StatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ApexAI" Height="420" Width="440"
        WindowStartupLocation="CenterScreen">
    <StackPanel Margin="20">
        <TextBlock x:Name="AccountText" FontWeight="Bold" FontSize="14" />
        <TextBlock x:Name="StatusText" Foreground="Gray" Margin="0,8,0,0" />

        <TextBlock Text="Последние круги" FontWeight="SemiBold" Margin="0,16,0,4" />
        <ListBox x:Name="LapsList" Height="190" />

        <TextBlock x:Name="PendingText" Foreground="Gray" Margin="0,10,0,0" />

        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
            <Button Content="Открыть кабинет" Click="OnOpenCabinet" Padding="10,5" Margin="0,0,8,0" />
            <Button Content="Выйти" Click="OnLogout" Padding="10,5" />
        </StackPanel>
    </StackPanel>
</Window>
