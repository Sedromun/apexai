# Copy to .env and adjust. Values below are wired for docker-compose (service names: db, minio).
# For a local (non-Docker) run, point hosts at localhost.

# --- App ---
APP_NAME=ApexAI
ENVIRONMENT=development
DEBUG=true

# --- Database ---
DATABASE_URL=postgresql+asyncpg://apexai:apexai@db:5432/apexai

# --- JWT ---
# Generate a strong secret for production:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=dev-insecure-secret-change-me-please-0123456789
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30

# --- Object storage (S3-compatible; MinIO in dev) ---
S3_ENDPOINT_URL=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=apexai
S3_SECRET_KEY=apexai-secret
S3_BUCKET=apexai-traces
S3_USE_PATH_STYLE=true

# --- CORS (comma-separated origins allowed to call the API) ---
CORS_ORIGINS=http://localhost:3000

# --- Limits ---
MAX_TRACE_UPLOAD_BYTES=5242880
